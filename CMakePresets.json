{
    "version": 6,
    "configurePresets": [
        {
            "name": "x64-Debug",
            "displayName": "x64 Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/x64-Debug",
            "installDir": "${sourceDir}/out/install/x64-Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "SCRIPTS": "static",
                "ELUNA": "ON",
                "TOOLS": "OFF",
                "SERVERS": "ON",
                "OPENSSL_CRYPTO_LIBRARY": "C:/Program Files/OpenSSL-Win64/lib/VC/x64/MD/libcrypto.lib",
                "OPENSSL_SSL_LIBRARY": "C:/Program Files/OpenSSL-Win64/lib/VC/x64/MD/libssl.lib",
                "LIB_EAY_RELEASE": "C:/Program Files/OpenSSL-Win64/lib/VC/x64/MD/libcrypto.lib",
                "SSL_EAY_RELEASE": "C:/Program Files/OpenSSL-Win64/lib/VC/x64/MD/libssl.lib"
            }
        },
        {
            "name": "x64-RelWithDebInfo",
            "displayName": "x64 RelWithDebInfo",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/x64-RelWithDebInfo",
            "installDir": "${sourceDir}/out/install/x64-RelWithDebInfo",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "SCRIPTS": "static",
                "ELUNA": "ON",
                "TOOLS": "OFF",
                "SERVERS": "ON",
                "OPENSSL_CRYPTO_LIBRARY": "C:/Program Files/OpenSSL-Win64/lib/VC/x64/MD/libcrypto.lib",
                "OPENSSL_SSL_LIBRARY": "C:/Program Files/OpenSSL-Win64/lib/VC/x64/MD/libssl.lib",
                "LIB_EAY_RELEASE": "C:/Program Files/OpenSSL-Win64/lib/VC/x64/MD/libcrypto.lib",
                "SSL_EAY_RELEASE": "C:/Program Files/OpenSSL-Win64/lib/VC/x64/MD/libssl.lib"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "x64-Debug",
            "configurePreset": "x64-Debug",
            "nativeToolOptions": ["-j20"]
        },
        {
            "name": "x64-Debug-scripts",
            "displayName": "x64 Debug (scripts only)",
            "configurePreset": "x64-Debug",
            "targets": ["scripts"],
            "nativeToolOptions": ["-j20"]
        },
        {
            "name": "x64-RelWithDebInfo",
            "configurePreset": "x64-RelWithDebInfo",
            "nativeToolOptions": ["-j20"]
        },
        {
            "name": "x64-RelWithDebInfo-scripts",
            "displayName": "x64 RelWithDebInfo (scripts only)",
            "configurePreset": "x64-RelWithDebInfo",
            "targets": ["scripts"],
            "nativeToolOptions": ["-j20"]
        }
    ]
}
