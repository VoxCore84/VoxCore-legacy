
# =============================================================================
# VoxCore .gitignore
# =============================================================================

# -- Build output -------------------------------------------------------------
build*/
out/
cmake-build-*/*
tools/build/

# -- IDE / editor -------------------------------------------------------------
.vs
.vscode
.idea/*
.browse.VC*
nbproject/*
CMakeLists.txt.user
*.user
.directory
.DS_Store
*.kdev*

# -- Merge / patch artifacts --------------------------------------------------
*.orig
*.rej
*.bak
*.patch
*.diff
*.REMOTE.*
*.BACKUP.*
*.BASE.*
*.LOCAL.*
*~

# -- External tools & data (own repos, large binaries) ------------------------
ExtTools/
wago/
wago-pipeline/
tools-dev/
website/
addons/
archive/

# -- In-tree addon dev branches (own repos) -----------------------------------
TransmogBridge_vNext/
TransmogSpy_vNext/

# -- Caches & generated data --------------------------------------------------
cache/
.cache/
__pycache__/
.opcode_cache.json

# -- SQL exports (generated, not source) --------------------------------------
sql/dumps/
sql/exports/locale/
sql/exports/existing_smartai_entries.txt
sql/exports/missing_smartai_entries.txt

# -- Legacy / one-off files ---------------------------------------------------
src/server/scripts/Custom/cs_custom.cpp
src/server/scripts/Custom/custom_commandscrip.cpp
Claude Code Prompts.txt
build_cli.bat

# -- Claude config (local-only) -----------------------------------------------
.claude.json
.clangd

# -- VCS artifacts ------------------------------------------------------------
.hg/
.mailmap
