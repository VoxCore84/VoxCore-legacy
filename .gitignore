
# =============================================================================
# VoxCore .gitignore
# =============================================================================

# -- Build output -------------------------------------------------------------
build*/
out/
cmake-build-*/*
tools/build/

# -- IDE / editor -------------------------------------------------------------
.vs
.vscode
.idea/*
.browse.VC*
nbproject/*
CMakeLists.txt.user
*.user
.directory
.DS_Store
*.kdev*

# -- Merge / patch artifacts --------------------------------------------------
*.orig
*.rej
*.bak
*.patch
*.diff
*.REMOTE.*
*.BACKUP.*
*.BASE.*
*.LOCAL.*
*~

# -- External tools & data (own repos, large binaries) ------------------------
ExtTools/
wago/
wago-pipeline/
tools-dev/
website/
addons/
archive/

# -- In-tree addon dev branches (own repos) -----------------------------------
TransmogBridge_vNext/
TransmogSpy_vNext/

# -- Caches & generated data --------------------------------------------------
cache/
.cache/
__pycache__/
.opcode_cache.json

# -- SQL exports & generated reports (not source) -----------------------------
sql/dumps/
sql/exports/locale/
sql/exports/existing_smartai_entries.txt
sql/exports/missing_smartai_entries.txt
sql/exports/cleanup/*.txt

# -- SQL old archives (historical TDB, keep only 12.x) -----------------------
sql/old/2.4.3/
sql/old/3.0.9/
sql/old/3.1.3/
sql/old/3.2.2a/
sql/old/3.3.2/
sql/old/3.3.3a/
sql/old/3.3.5a/
sql/old/4.2.2/
sql/old/4.3.4/
sql/old/6.x/
sql/old/7/
sql/old/8.x/
sql/old/9.x/
sql/old/10.x/
sql/old/11.x/

# -- Legacy / one-off files ---------------------------------------------------
src/server/scripts/Custom/cs_custom.cpp
src/server/scripts/Custom/custom_commandscrip.cpp
Claude Code Prompts.txt
build_cli.bat

# -- Claude config (local-only) -----------------------------------------------
.claude.json
.clangd

# -- VCS artifacts ------------------------------------------------------------
.hg/
.mailmap
