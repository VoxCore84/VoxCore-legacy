{
    "version": 1,
    "central_brain": "AI_Studio/0_Central_Brain.md",
    "manifest_dir": "logs/orchestrator/runs",
    "latest_manifest": "logs/orchestrator/latest_run_manifest.json",
    "latest_summary": "logs/orchestrator/latest_run_summary.md",
    "lock_file": "logs/orchestrator/locks/current.lock",
    "default_timeout_sec": 1800,
    "jobs": {
        "headless_build": {
            "adapter": "headless_build",
            "timeout_sec": 3600,
            "allowed_flags": ["preset", "target", "configuration", "dry_run", "no_extract"]
        },
        "architect_spec": {
            "adapter": "architect_spec",
            "timeout_sec": 1800,
            "allowed_flags": ["intake", "mode", "force", "model"]
        },
        "claude_implement": {
            "adapter": "claude_code",
            "timeout_sec": 3600,
            "allowed_flags": ["spec_file", "dry_run"]
        },
        "auto_retry_loop": {
            "adapter": "auto_retry",
            "timeout_sec": 7200,
            "allowed_flags": ["spec_file", "preset", "dry_run"]
        }
    }
}
